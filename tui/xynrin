show_banner() {
    show_logo
    echo -e "  ${BOLD}${CYAN}Version${RESET}  ${GREEN}v${CURRENT_VERSION}${RESET}"
    echo -e "  ${BOLD}${CYAN}Author${RESET}   ${GREEN}${AUTHOR}${RESET}"
    echo -e "  ${BOLD}${CYAN}Repo${RESET}     ${BLUE}${REPO_HTTPS}${RESET}"
    echo ""
}

# ============================================================
# 1. жӣҙж–° xynrin / Self-update
# ============================================================
do_update() {
    echo -e "${CYAN}${MSG_UPDATING}${RESET}"

    local remote
    remote="$(curl -sL "${REPO_RAW}/scripts/version" 2>/dev/null | tr -d '[:space:]')"
    if [[ -z "$remote" ]]; then
        echo -e "${RED}${MSG_UPDATE_FAILED}${RESET}"
        return 1
    fi

    echo -e "${MSG_CURRENT_VERSION}: ${GREEN}${CURRENT_VERSION}${RESET}"
    echo -e "${MSG_LATEST_VERSION}:  ${GREEN}${remote}${RESET}"

    if [[ "$CURRENT_VERSION" == "$remote" ]]; then
        echo -e "${GREEN}${MSG_ALREADY_LATEST}${RESET}"
        return 0
    fi

    echo -e "${YELLOW}${MSG_UPDATE_AVAILABLE}${RESET} (${CURRENT_VERSION} -> ${remote})"

    if ! command -v git &> /dev/null || [[ ! -d "$PROJECT_ROOT/.git" ]]; then
        echo -e "${RED}${MSG_UPDATE_FAILED}${RESET}"
        return 1
    fi

    # жӢүеҸ–жңҖж–°д»Јз Ғ / Pull latest code
    ( cd "$PROJECT_ROOT" && git pull --ff-only origin main )

    # йҮҚж–°жү§иЎҢ install.sh еә”з”ЁиҝҒз§»пјҲеҰӮйҮҚе‘ҪеҗҚдёә xynrinпјү
    # Re-run install.sh to apply migrations (e.g. rename to xynrin)
    echo -e "${CYAN}${MSG_APPLYING_MIGRATION}${RESET}"
    bash "$INSTALL_SCRIPT" --upgrade
    echo -e "${GREEN}${MSG_UPDATE_DONE}${RESET}"
}

# ============================================================
# 2. е®үиЈ… proot еҸ‘иЎҢзүҲ / Install proot distro
# ============================================================
proot_install() {
    if ! command -v proot-distro &> /dev/null; then
        echo -e "${RED}proot-distro not found${RESET}"
        return 1
    fi

    echo -e "${CYAN}${MSG_PROOT_DISTRO_NAME}${RESET}"
    echo -e "${YELLOW}${MSG_PROOT_DISTRO_EXAMPLE}${RESET}"
    echo -n "> "
    read -r distro

    if [[ -z "$distro" ]]; then
        echo -e "${RED}${MSG_INVALID_CHOICE}${RESET}"
        return 1
    fi

    echo -e "${CYAN}${MSG_PROOT_INSTALLING} ${distro}...${RESET}"
    if proot-distro install "$distro"; then
        setup_distro_alias "$distro"
        echo -e "${GREEN}${MSG_PROOT_INSTALL_DONE}${RESET}"
        echo -e "${CYAN}${MSG_ALIAS_CONFIGURED}: ${BOLD}${distro}${RESET}"
        echo -e "${YELLOW}${MSG_ALIAS_RESTART_HINT}${RESET}"
    else
        echo -e "${RED}${MSG_PROOT_INSTALL_FAILED}${RESET}"
    fi
}

# дёәеҸ‘иЎҢзүҲи®ҫзҪ®еҲ«еҗҚ / Set up an alias for a distro
setup_distro_alias() {
    local distro="$1"
    local alias_line="alias ${distro}='proot-distro login ${distro}'"
    local rc="$HOME/.bashrc"

    # еҶҷе…Ҙ .bashrcпјҲеҰӮжһңиҝҳжІЎжңүпјү/ Add to .bashrc if missing
    if ! grep -qF "$alias_line" "$rc" 2>/dev/null; then
        echo "$alias_line" >> "$rc"
    fi

    # и®°еҪ•еҲ° .aliases зҙўеј•ж–Үд»¶ / Record in .aliases index
    if ! grep -qx "$distro" "$ALIASES_FILE" 2>/dev/null; then
        echo "$distro" >> "$ALIASES_FILE"
    fi
}

# ============================================================
# 3. еҲ—еҮәзңҹе®һеҸҜз”Ёзҡ„еҲ«еҗҚ / List actual usable aliases
# ============================================================
list_aliases() {
    echo -e "${BOLD}${CYAN}${MSG_ALIASES_TITLE}${RESET}"
    echo ""

    if ! command -v proot-distro &> /dev/null; then
        echo -e "${YELLOW}${MSG_PROOT_NOT_INSTALLED}${RESET}"
        return 0
    fi

    # еҸ–е·Іе®үиЈ…еҸ‘иЎҢзүҲдёҺ .bashrc дёӯзҡ„еҲ«еҗҚеҒҡдәӨйӣҶпјҢзЎ®дҝқеұ•зӨәзҡ„йғҪзңҹе®һеҸҜз”Ё
    # Intersect installed distros with aliases defined in .bashrc to
    # ensure every shown entry is actually usable
    local installed
    installed="$(proot-distro list --installed 2>/dev/null | grep -E '^[a-z]' | awk '{print $1}')"

    if [[ -z "$installed" ]]; then
        echo -e "  ${YELLOW}${MSG_PROOT_NOT_INSTALLED}${RESET}"
        return 0
    fi

    local rc="$HOME/.bashrc"
    local found=0
    while IFS= read -r distro; do
        local alias_line="alias ${distro}='proot-distro login ${distro}'"
        if grep -qF "$alias_line" "$rc" 2>/dev/null; then
            echo -e "  ${GREEN}${distro}${RESET}  вҶ’  proot-distro login ${distro}"
            found=1
        fi
    done <<< "$installed"

    if [[ $found -eq 0 ]]; then
        echo -e "  ${YELLOW}${MSG_NO_ALIAS}${RESET}"
        return 0
    fi

    echo ""
    echo -e "${YELLOW}${MSG_ALIAS_RESTART_HINT}${RESET}"
}

# ============================================================
# 4. зі»з»ҹдҝЎжҒҜ / System info
# ============================================================
show_system_info() {
    echo -e "${BOLD}${CYAN}${MSG_SYSTEM_INFO}${RESET}"
    echo -e "  ${GREEN}${MSG_OS}:${RESET}        $(uname -o 2>/dev/null || uname -s)"
    echo -e "  ${GREEN}${MSG_ARCH}:${RESET}        $(uname -m)"
    echo -e "  ${GREEN}${MSG_KERNEL}:${RESET}      $(uname -r)"
    echo -e "  ${GREEN}${MSG_SHELL}:${RESET}       $SHELL"
    if [[ -n "${TERMUX_VERSION:-}" ]]; then
        echo -e "  ${GREEN}${MSG_TERMUX_VERSION}:${RESET} ${TERMUX_VERSION}"
    fi
    if command -v fastfetch &> /dev/null; then
        echo ""
        fastfetch
    fi
}

# ============================================================
# 5. ж·»еҠ жҲ–и®ҫзҪ®й•ңеғҸжәҗ / Configure mirror sources
# ============================================================
configure_mirror() {
    echo -e "${BOLD}${CYAN}${MSG_MIRROR_TITLE}${RESET}"
    echo ""
    echo -e "  ${GREEN}1)${RESET} ${MSG_MIRROR_INTERACTIVE} (termux-change-repo)"
    echo -e "  ${GREEN}2)${RESET} ${MSG_MIRROR_TSINGHUA}"
    echo -e "  ${GREEN}3)${RESET} ${MSG_MIRROR_USTC}"
    echo -e "  ${GREEN}4)${RESET} ${MSG_MIRROR_OFFICIAL}"
    echo -e "  ${GREEN}0)${RESET} ${OPT_BACK}"
    echo ""
    echo -n "> "
    read -r choice

    case "$choice" in
        1)
            if command -v termux-change-repo &> /dev/null; then
                termux-change-repo
            else
                echo -e "${RED}termux-change-repo not found${RESET}"
                echo -e "${YELLOW}pkg install termux-tools${RESET}"
            fi
            ;;
        2) apply_mirror "https://mirrors.tuna.tsinghua.edu.cn/termux/apt/termux-main" "Tsinghua" ;;
        3) apply_mirror "https://mirrors.ustc.edu.cn/termux/apt/termux-main" "USTC" ;;
        4) apply_mirror "https://packages.termux.dev/apt/termux-main" "Official" ;;
        0) return 0 ;;
        *) echo -e "${RED}${MSG_INVALID_CHOICE}${RESET}" ;;
    esac
}

apply_mirror() {
    local url="$1"
    local name="$2"
    local sources="$PREFIX/etc/apt/sources.list"

    echo -e "${CYAN}${MSG_MIRROR_APPLYING} ${name}...${RESET}"

    # еӨҮд»ҪеҺҹж–Үд»¶ / Backup original
    cp "$sources" "${sources}.bak.$(date +%s)"

    # еҶҷе…Ҙж–°жәҗ / Write new source
    echo "deb $url stable main" > "$sources"

    echo -e "${GREEN}${MSG_MIRROR_APPLIED}: ${name}${RESET}"
    echo -e "${CYAN}${MSG_MIRROR_UPDATING}${RESET}"
    pkg update -y || echo -e "${YELLOW}${MSG_MIRROR_UPDATE_WARN}${RESET}"
}

# ============================================================
# TUI дё»иҸңеҚ• / TUI main menu
# ============================================================
show_menu() {
    while true; do
        echo ""
        echo -e "${BOLD}${CYAN}=== ${MENU_TITLE} ===${RESET}"
        echo -e "  ${GREEN}1)${RESET} ${OPT_UPDATE}"
        echo -e "  ${GREEN}2)${RESET} ${OPT_PROOT_INSTALL}"
        echo -e "  ${GREEN}3)${RESET} ${OPT_LIST_ALIASES}"
        echo -e "  ${GREEN}4)${RESET} ${OPT_SYSTEM_INFO}"
        echo -e "  ${GREEN}5)${RESET} ${OPT_MIRROR}"
        echo -e "  ${GREEN}6)${RESET} ${OPT_EXIT}"
        echo ""
        echo -n "> "
        read -r choice

        case "$choice" in
            1) do_update ;;
            2) proot_install ;;
            3) list_aliases ;;
            4) show_system_info ;;
            5) configure_mirror ;;
            6|0|q|Q) echo -e "${GREEN}${MSG_GOODBYE}${RESET}"; exit 0 ;;
            *) echo -e "${RED}${MSG_INVALID_CHOICE}${RESET}" ;;
        esac

        echo ""
        echo -n "${MSG_PRESS_ENTER}"
        read -r _
    done
}

# ============================================================
# CLI / CLI commands
# ============================================================
show_help() {
    show_banner
    echo -e "${CLI_HELP_USAGE}"
    echo ""
    echo -e "${CLI_HELP_CMDS}"
    echo -e "${CLI_HELP_MENU}"
    echo -e "${CLI_HELP_HELP}"
    echo -e "${CLI_HELP_VERSION}"
    echo -e "${CLI_HELP_UPDATE}"
}

show_version() { echo "xynrin v${CURRENT_VERSION}"; }

# ============================================================
# е…ҘеҸЈ / Entry point
# ============================================================
main() {
    load_language "$(get_language_pref)"

    case "${1:-menu}" in
        help|-h|--help)        show_help ;;
        version|-v|--version)  show_version ;;
        update|-u|--update)    do_update ;;
        menu|"")
            show_banner
            echo -e "${BOLD}${MSG_WELCOME}${RESET}"
            show_menu
            ;;
        *)
            echo -e "${RED}Unknown command: $1${RESET}"
            echo ""
            show_help
            exit 1
            ;;
    esac
}

main "$@"
