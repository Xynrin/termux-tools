# ============================================================
# ŤĮ≠Ť®ÄŚä†ŤĹĹ / Language loading
# ============================================================
LANG_PREF_FILE="$PROJECT_ROOT/.lang_pref"

detect_language() {
    local lang_env="${LANG:-${LC_ALL:-en_US}}"
    if [[ "$lang_env" == *zh* ]] || [[ "$lang_env" == *CN* ]] || [[ "$lang_env" == *TW* ]]; then
        echo "zh"
    else
        echo "en"
    fi
}

get_language_pref() {
    [[ -f "$LANG_PREF_FILE" ]] && cat "$LANG_PREF_FILE" || detect_language
}

save_language_pref() {
    echo "$1" > "$LANG_PREF_FILE"
}

load_language() {
    local code="${1:-$(detect_language)}"
    local file="$LANG_DIR/${code}.sh"
    [[ -f "$file" ]] && source "$file" || source "$LANG_DIR/en.sh"
}

# ============================================================
# fzf Ťá™Śä®ŚģČŤ£Ö / Auto-install fzf
# ============================================================
ensure_fzf() {
    if command -v fzf &> /dev/null; then
        return 0
    fi
    echo -e "${YELLOW}${MSG_FZF_INSTALLING:-Installing fzf...}${RESET}"
    if command -v pkg &> /dev/null; then
        pkg install -y fzf || return 1
    elif command -v apt &> /dev/null; then
        apt install -y fzf || return 1
    else
        return 1
    fi
}

# fzf ťÄČśč©ŚįĀŤ£ÖÔľöŤŅĒŚõěťÄČšł≠Ť°ĆÔľąŚéĽťô§ŚČćÁľÄÁľĖŚŹ∑ÔľČ
# fzf wrapper: returns selected line (without leading index)
# ÁĒ®ś≥ē / Usage: fzf_pick "Title" "1) Option A" "2) Option B" ...
fzf_pick() {
    local title="$1"; shift
    printf '%s\n' "$@" | fzf \
        --ansi \
        --prompt="$title > " \
        --height=40% \
        --reverse \
        --no-info \
        --border=rounded \
        --color='border:cyan,prompt:yellow,pointer:green,marker:green'
}

