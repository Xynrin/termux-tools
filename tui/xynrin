set -euo pipefail

# ============================================================
# и·Ҝеҫ„и§ЈжһҗпјҲи·ҹйҡҸз¬ҰеҸ·й“ҫжҺҘеҲ°зңҹе®һж–Үд»¶пјү
# Path resolution (follow symlinks to the real file)
# ============================================================
REAL_SCRIPT="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$REAL_SCRIPT")" &> /dev/null && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

VERSION_FILE="$PROJECT_ROOT/scripts/version"
LANG_DIR="$SCRIPT_DIR/lang"
INSTALL_SCRIPT="$PROJECT_ROOT/install.sh"
ALIASES_FILE="$PROJECT_ROOT/.aliases"   # жҢҒд№…еҢ–е·Ій…ҚзҪ®зҡ„еҲ«еҗҚ / persisted alias list

REPO_HTTPS="https://github.com/Xynrin/termux-tools"
REPO_RAW="https://raw.githubusercontent.com/Xynrin/termux-tools/main"

CURRENT_VERSION="$(cat "$VERSION_FILE" 2>/dev/null || echo "unknown")"
AUTHOR="Xynrin"

# ============================================================
# йўңиүІ / Colors
# ============================================================
RED='\e[31m'
GREEN='\e[32m'
YELLOW='\e[33m'
BLUE='\e[34m'
MAGENTA='\e[35m'
CYAN='\e[36m'
ORANGE='\e[38;5;202m'
PINK='\e[38;5;213m'
BOLD='\e[1m'
RESET='\e[0m'

# ============================================================
# иҜӯиЁҖеҠ иҪҪ / Language loading
# ============================================================
LANG_PREF_FILE="$PROJECT_ROOT/.lang_pref"

detect_language() {
    local lang_env="${LANG:-${LC_ALL:-en_US}}"
    if [[ "$lang_env" == *zh* ]] || [[ "$lang_env" == *CN* ]] || [[ "$lang_env" == *TW* ]]; then
        echo "zh"
    else
        echo "en"
    fi
}

get_language_pref() {
    if [[ -f "$LANG_PREF_FILE" ]]; then
        cat "$LANG_PREF_FILE"
    else
        detect_language
    fi
}

save_language_pref() { echo "$1" > "$LANG_PREF_FILE"; }

load_language() {
    local code="${1:-$(detect_language)}"
    local file="$LANG_DIR/${code}.sh"
    if [[ -f "$file" ]]; then
        source "$file"
    else
        source "$LANG_DIR/en.sh"
    fi
}

