# ============================================================
# 1. Ťá™śąĎśõīśĖį / Self-update
# ============================================================
do_update() {
    echo -e "${CYAN}${MSG_UPDATING}${RESET}"
    local remote
    remote="$(curl -sL "${REPO_RAW}/scripts/version" 2>/dev/null | tr -d '[:space:]')"
    if [[ -z "$remote" ]]; then
        echo -e "${RED}${MSG_UPDATE_FAILED}${RESET}"
        return 1
    fi

    echo -e "${MSG_CURRENT_VERSION}: ${GREEN}${CURRENT_VERSION}${RESET}"
    echo -e "${MSG_LATEST_VERSION}:  ${GREEN}${remote}${RESET}"

    if [[ "$CURRENT_VERSION" == "$remote" ]]; then
        echo -e "${GREEN}${MSG_ALREADY_LATEST}${RESET}"
        return 0
    fi

    echo -e "${YELLOW}${MSG_UPDATE_AVAILABLE}${RESET} (${CURRENT_VERSION} -> ${remote})"

    if ! command -v git &> /dev/null || [[ ! -d "$PROJECT_ROOT/.git" ]]; then
        echo -e "${RED}${MSG_UPDATE_FAILED}${RESET}"
        return 1
    fi

    # šłĘŚľÉŤ∑üŤł™śĖášĽ∂ÁöĄśú¨ŚúįśĒĻŚä®ÔľĆťĀŅŚÖć git pull Śõ†ŚÜ≤Á™Āšł≠ś≠Ę
    # Discard local changes to tracked files so git pull won't abort
    # (xynrin/install.sh Á≠ČťÉĹśėĮšĽďŚļďÁģ°ÁźÜśĖášĽ∂ÔľĆśú¨ŚúįśĒĻŚä®ťÄöŚłłśėĮŤĮĮŚÖ•)
    ( cd "$PROJECT_ROOT" && git checkout -- . 2>/dev/null || true )
    ( cd "$PROJECT_ROOT" && git pull --ff-only origin main )

    echo -e "${CYAN}${MSG_APPLYING_MIGRATION}${RESET}"
    bash "$INSTALL_SCRIPT" --upgrade
    echo -e "${GREEN}${MSG_UPDATE_DONE}${RESET}"
}

# ============================================================
# 2. ŚģČŤ£Ö proot ŚŹĎŤ°ĆÁČą / Install proot distro
# ============================================================
proot_install() {
    if ! command -v proot-distro &> /dev/null; then
        echo -e "${RED}proot-distro not found${RESET}"
        return 1
    fi

    # ŚąóŚáļ proot-distro śĒĮśĆĀÁöĄŚŹĎŤ°ĆÁČąšĺõťÄČśč© / list available distros
    local available
    available="$(proot-distro list 2>/dev/null \
        | awk '/^[[:space:]]*[a-z][a-z0-9-]*[[:space:]]*$/{print $1}' \
        | sort -u)"

    # ŚÖľŚģĻŤÄĀś†ľŚľŹ / fallback if format differs
    if [[ -z "$available" ]]; then
        available="ubuntu
debian
archlinux
fedora
alpine
void
opensuse"
    fi

    local picked
    if command -v fzf &> /dev/null; then
        picked="$(echo "$available" | fzf \
            --prompt="${MSG_PROOT_DISTRO_NAME} > " \
            --height=50% --reverse --no-info --border=rounded \
            --color='border:cyan,prompt:yellow,pointer:green')" || return 0
    else
        echo -e "${CYAN}${MSG_PROOT_DISTRO_NAME}${RESET}"
        echo -e "${YELLOW}${MSG_PROOT_DISTRO_EXAMPLE}${RESET}"
        echo -n "> "
        read -r picked
    fi

    if [[ -z "$picked" ]]; then
        echo -e "${RED}${MSG_INVALID_CHOICE}${RESET}"
        return 1
    fi

    echo -e "${CYAN}${MSG_PROOT_INSTALLING} ${picked}...${RESET}"
    if proot-distro install "$picked"; then
        setup_distro_alias "$picked"
        echo -e "${GREEN}${MSG_PROOT_INSTALL_DONE}${RESET}"
        echo -e "${CYAN}${MSG_ALIAS_CONFIGURED}: ${BOLD}${picked}${RESET}"
        echo -e "${YELLOW}${MSG_ALIAS_RESTART_HINT}${RESET}"
    else
        echo -e "${RED}${MSG_PROOT_INSTALL_FAILED}${RESET}"
    fi
}

setup_distro_alias() {
    local distro="$1"
    local alias_line="alias ${distro}='proot-distro login ${distro}'"
    local rc="$HOME/.bashrc"
    touch "$rc"
    grep -qF "$alias_line" "$rc" 2>/dev/null || echo "$alias_line" >> "$rc"
    grep -qx "$distro" "$ALIASES_FILE" 2>/dev/null || echo "$distro" >> "$ALIASES_FILE"
}

# ============================================================
# 3. ŚąóŚáļŚ∑≤ŚģČŤ£ÖšłĒŚ∑≤ťÖćÁĹģŚąęŚźćÁöĄŚŹĎŤ°ĆÁČą / List real, usable aliases
# ============================================================
list_installed_distros() {
    # ŚÖľŚģĻŚ§öÁßć proot-distro ŤĺďŚáļś†ľŚľŹ / compatible with multiple proot-distro output formats
    # ŤÄĀÁČąś†ľŚľŹÔľöšĽ•ŚįŹŚÜôŚ≠óśĮćŚľÄŚ§ī / old: lowercase-leading
    # śĖįÁČąś†ľŚľŹÔľö'* ubuntu' śąĖÁľ©ŤŅõ / new: '* ubuntu' or indented
    proot-distro list --installed 2>/dev/null \
        | sed -E 's/^[[:space:]]*\*?[[:space:]]*//' \
        | awk '/^[a-z][a-z0-9-]*([[:space:]]|$)/{print $1}' \
        | sort -u
}

list_aliases() {
    echo -e "${BOLD}${CYAN}${MSG_ALIASES_TITLE}${RESET}"
    echo ""

    if ! command -v proot-distro &> /dev/null; then
        echo -e "  ${YELLOW}${MSG_PROOT_NOT_INSTALLED}${RESET}"
        return 0
    fi

    local installed
    installed="$(list_installed_distros || true)"

    if [[ -z "$installed" ]]; then
        echo -e "  ${YELLOW}${MSG_PROOT_NOT_INSTALLED}${RESET}"
        return 0
    fi

    local rc="$HOME/.bashrc"
    local found=0
    local distro
    while IFS= read -r distro; do
        [[ -z "$distro" ]] && continue
        local alias_line="alias ${distro}='proot-distro login ${distro}'"
        if [[ -f "$rc" ]] && grep -qF "$alias_line" "$rc" 2>/dev/null; then
            echo -e "  ${GREEN}${distro}${RESET}  ‚Üí  proot-distro login ${distro}"
            found=1
        else
            # Ś∑≤ŚģČŤ£ÖšĹÜś≤°ŚąęŚźćÔľöŤá™Śä®Ť°•šłä / installed but no alias: add it now
            setup_distro_alias "$distro"
            echo -e "  ${GREEN}${distro}${RESET}  ‚Üí  proot-distro login ${distro}  ${YELLOW}(auto-added)${RESET}"
            found=1
        fi
    done <<< "$installed"

    if [[ $found -eq 0 ]]; then
        echo -e "  ${YELLOW}${MSG_NO_ALIAS}${RESET}"
        return 0
    fi

    echo ""
    echo -e "${YELLOW}${MSG_ALIAS_RESTART_HINT}${RESET}"
}

# ============================================================
# 4. Á≥ĽÁĽüšŅ°śĀĮ / System info
# ============================================================
show_system_info() {
    echo -e "${BOLD}${CYAN}${MSG_SYSTEM_INFO}${RESET}"
    echo -e "  ${GREEN}${MSG_OS}:${RESET}        $(uname -o 2>/dev/null || uname -s)"
    echo -e "  ${GREEN}${MSG_ARCH}:${RESET}        $(uname -m)"
    echo -e "  ${GREEN}${MSG_KERNEL}:${RESET}      $(uname -r)"
    echo -e "  ${GREEN}${MSG_SHELL}:${RESET}       $SHELL"
    [[ -n "${TERMUX_VERSION:-}" ]] && \
        echo -e "  ${GREEN}${MSG_TERMUX_VERSION}:${RESET} ${TERMUX_VERSION}"
    if command -v fastfetch &> /dev/null; then
        echo ""
        fastfetch || true
    fi
}

# ============================================================
# 5. ťēúŚÉŹśļź / Mirror sources
# ============================================================
configure_mirror() {
    local options=(
        "1) ${MSG_MIRROR_INTERACTIVE} (termux-change-repo)"
        "2) ${MSG_MIRROR_TSINGHUA}"
        "3) ${MSG_MIRROR_USTC}"
        "4) ${MSG_MIRROR_OFFICIAL}"
        "0) ${OPT_BACK}"
    )

    local picked
    if command -v fzf &> /dev/null; then
        picked="$(fzf_pick "${MSG_MIRROR_TITLE}" "${options[@]}")" || return 0
    else
        echo -e "${BOLD}${CYAN}${MSG_MIRROR_TITLE}${RESET}"
        printf '  %s\n' "${options[@]}"
        echo -n "> "
        read -r raw
        picked="${raw}) "
    fi

    case "$picked" in
        1*)
            if command -v termux-change-repo &> /dev/null; then
                termux-change-repo || true
            else
                echo -e "${RED}termux-change-repo not found${RESET}"
                echo -e "${YELLOW}pkg install termux-tools${RESET}"
            fi
            ;;
        2*) apply_mirror "https://mirrors.tuna.tsinghua.edu.cn/termux/apt/termux-main" "Tsinghua" ;;
        3*) apply_mirror "https://mirrors.ustc.edu.cn/termux/apt/termux-main" "USTC" ;;
        4*) apply_mirror "https://packages.termux.dev/apt/termux-main" "Official" ;;
        0*|"") return 0 ;;
        *) echo -e "${RED}${MSG_INVALID_CHOICE}${RESET}" ;;
    esac
}

apply_mirror() {
    local url="$1"
    local name="$2"
    local sources="$PREFIX/etc/apt/sources.list"

    echo -e "${CYAN}${MSG_MIRROR_APPLYING} ${name}...${RESET}"

    # ŚģČŚÖ®Ś§ášĽĹÔľöšĽÖŚú®śļźśĖášĽ∂Ś≠ėŚú®śó∂Ś§ášĽĹ / Backup only if source exists
    if [[ -f "$sources" ]]; then
        cp "$sources" "${sources}.bak.$(date +%s)" 2>/dev/null || \
            echo -e "${YELLOW}${MSG_MIRROR_BACKUP_WARN}${RESET}"
    fi

    # ŚÜôŚÖ•śĖįśļźÔľõŤč•śó†ŚÜôśĚÉťôźŚįĪśä•ťĒôŤÄĆšłćśėĮťÄÄŚáļ / Write new source; warn on perm issue
    if ! echo "deb $url stable main" > "$sources" 2>/dev/null; then
        echo -e "${RED}${MSG_MIRROR_WRITE_FAIL}: $sources${RESET}"
        return 1
    fi

    echo -e "${GREEN}${MSG_MIRROR_APPLIED}: ${name}${RESET}"
    echo -e "${CYAN}${MSG_MIRROR_UPDATING}${RESET}"
    pkg update -y || echo -e "${YELLOW}${MSG_MIRROR_UPDATE_WARN}${RESET}"
}

# ============================================================
# 6. ŚąáśćĘŤĮ≠Ť®Ä / Change language
# ============================================================
change_language() {
    local options=(
        "1) šł≠śĖá (zh)"
        "2) English (en)"
        "0) ${OPT_BACK}"
    )

    local picked
    if command -v fzf &> /dev/null; then
        picked="$(fzf_pick "${LANG_TITLE}" "${options[@]}")" || return 0
    else
        echo -e "${BOLD}${LANG_TITLE}${RESET}"
        printf '  %s\n' "${options[@]}"
        echo -n "> "
        read -r raw
        picked="${raw}) "
    fi

    case "$picked" in
        1*) save_language_pref "zh"; load_language "zh"
            echo -e "${GREEN}${MSG_LANG_SWITCHED}${RESET}" ;;
        2*) save_language_pref "en"; load_language "en"
            echo -e "${GREEN}${MSG_LANG_SWITCHED}${RESET}" ;;
        0*|"") return 0 ;;
        *) echo -e "${RED}${MSG_INVALID_CHOICE}${RESET}" ;;
    esac
}

# ============================================================
# šłĽŤŹúŚćē / Main menu (fzf-driven)
# ============================================================
show_menu() {
    while true; do
        # śĮŹŤĹģťáćśĖįśěĄťÄ†ÔľĆšĹŅŚąáśćĘŤĮ≠Ť®ÄŚźéŤŹúŚćēśĖáś°ąÁęčŚć≥Śą∑śĖį
        # Rebuild each loop so menu text refreshes after language switch
        local options=(
            "1) ${OPT_UPDATE}"
            "2) ${OPT_PROOT_INSTALL}"
            "3) ${OPT_LIST_ALIASES}"
            "4) ${OPT_SYSTEM_INFO}"
            "5) ${OPT_MIRROR}"
            "6) ${OPT_LANGUAGE}"
            "7) ${OPT_EXIT}"
        )

        echo ""
        local picked
        if command -v fzf &> /dev/null; then
            picked="$(fzf_pick "${MENU_TITLE}" "${options[@]}")" || picked="7"
        else
            echo -e "${BOLD}${CYAN}=== ${MENU_TITLE} ===${RESET}"
            printf '  %s\n' "${options[@]}"
            echo -n "> "
            read -r raw
            picked="${raw}) "
        fi

        case "$picked" in
            1*) do_update ;;
            2*) proot_install ;;
            3*) list_aliases ;;
            4*) show_system_info ;;
            5*) configure_mirror ;;
            6*) change_language ;;
            7*|0*|"") echo -e "${GREEN}${MSG_GOODBYE}${RESET}"; exit 0 ;;
            *) echo -e "${RED}${MSG_INVALID_CHOICE}${RESET}" ;;
        esac

        echo ""
        echo -n "${MSG_PRESS_ENTER}"
        read -r _ || true
    done
}

# ============================================================
# CLI / CLI commands
# ============================================================
show_help() {
    show_banner
    echo -e "${CLI_HELP_USAGE}"
    echo ""
    echo -e "${CLI_HELP_CMDS}"
    echo -e "${CLI_HELP_MENU}"
    echo -e "${CLI_HELP_HELP}"
    echo -e "${CLI_HELP_VERSION}"
    echo -e "${CLI_HELP_UPDATE}"
}

show_version() { echo "xynrin v${CURRENT_VERSION}"; }

# ============================================================
# Entry / ŚÖ•ŚŹ£
# ============================================================
main() {
    load_language "$(get_language_pref)"

    case "${1:-menu}" in
        help|-h|--help)        show_help ;;
        version|-v|--version)  show_version ;;
        update|-u|--update)    do_update ;;
        menu|"")
            ensure_fzf || echo -e "${YELLOW}${MSG_FZF_FALLBACK:-fzf unavailable, using fallback prompt}${RESET}"
            show_banner
            echo -e "${BOLD}${MSG_WELCOME}${RESET}"
            show_menu
            ;;
        *)
            echo -e "${RED}Unknown command: $1${RESET}"
            echo ""
            show_help
            exit 1
            ;;
    esac
}

main "$@"
