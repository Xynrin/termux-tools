#!/usr/bin/env bash
#
# xynrin - Termux 辅助 TUI / Termux helper TUI (薄派发壳 / thin dispatcher)
# License: GPL-v3   Author: Xynrin   Repo: https://github.com/Xynrin/termux-tools
#
# 这个壳负责：
#   1. 解析路径、加载语言包
#   2. 把 --menu-* / 顶级子命令派发到 tui/modules/*.sh
#   3. 提供纯 bash 兜底菜单（Rust 二进制不可用时）
# This shell:
#   1. Resolves paths, loads language pack
#   2. Dispatches --menu-* / top-level subcommands to tui/modules/*.sh
#   3. Provides a pure-bash fallback menu (when the Rust binary is unavailable)
#
set -uo pipefail

REAL_SCRIPT="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$REAL_SCRIPT")" &> /dev/null && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

VERSION_FILE="$PROJECT_ROOT/scripts/version"
LANG_DIR="$SCRIPT_DIR/lang"
MODULES_DIR="$SCRIPT_DIR/modules"
LANG_PREF_FILE="$PROJECT_ROOT/.lang_pref"

CURRENT_VERSION="$(cat "$VERSION_FILE" 2>/dev/null || echo unknown)"
AUTHOR="Xynrin"
REPO_HTTPS="https://github.com/Xynrin/termux-tools"

RED='\e[31m'; GREEN='\e[32m'; YELLOW='\e[33m'; BLUE='\e[34m'
CYAN='\e[36m'; ORANGE='\e[38;5;202m'; BOLD='\e[1m'; RESET='\e[0m'

# ============================================================
# 语言加载 / Language loading
# ============================================================
detect_language() {
    local e="${LANG:-${LC_ALL:-en_US}}"
    [[ "$e" == *zh* || "$e" == *CN* || "$e" == *TW* ]] && echo "zh" || echo "en"
}
get_language_pref() { [[ -f "$LANG_PREF_FILE" ]] && cat "$LANG_PREF_FILE" || detect_language; }
load_language() {
    local code="${1:-$(detect_language)}"
    local f="$LANG_DIR/${code}.sh"
    [[ -f "$f" ]] && source "$f" || source "$LANG_DIR/en.sh"
}

# ============================================================
# 模块加载 / Module loading
# ============================================================
load_module() { source "$MODULES_DIR/$1.sh"; }

# ============================================================
# fzf 自动安装 / Auto-install fzf (兜底菜单需要)
# ============================================================
ensure_fzf() {
    command -v fzf &> /dev/null && return 0
    command -v pkg &> /dev/null && pkg install -y fzf &> /dev/null
}

# ============================================================
# Banner（纯 bash 模式打印；Rust 模式由 ratatui 画）
# ============================================================
show_logo() {
    local c1='\e[38;5;202m' c2='\e[38;5;208m' c3='\e[38;5;214m' c4='\e[38;5;220m' c5='\e[38;5;226m'
    echo ""
    echo -e "${BOLD}${c1} ██╗  ██╗██╗   ██╗███╗   ██╗██████╗ ██╗███╗   ██╗${RESET}"
    echo -e "${BOLD}${c2} ╚██╗██╔╝╚██╗ ██╔╝████╗  ██║██╔══██╗██║████╗  ██║${RESET}"
    echo -e "${BOLD}${c3}  ╚███╔╝  ╚████╔╝ ██╔██╗ ██║██████╔╝██║██╔██╗ ██║${RESET}"
    echo -e "${BOLD}${c4}  ██╔██╗   ╚██╔╝  ██║╚██╗██║██╔══██╗██║██║╚██╗██║${RESET}"
    echo -e "${BOLD}${c5} ██╔╝ ██╗   ██║   ██║ ╚████║██║  ██║██║██║ ╚████║${RESET}"
    echo -e "${BOLD}${c5} ╚═╝  ╚═╝   ╚═╝   ╚═╝  ╚═══╝╚═╝  ╚═╝╚═╝╚═╝  ╚═══╝${RESET}"
    echo ""
}
show_banner() {
    show_logo
    echo -e "  ${BOLD}${CYAN}Version${RESET}  ${GREEN}v${CURRENT_VERSION}${RESET}"
    echo -e "  ${BOLD}${CYAN}Author${RESET}   ${GREEN}${AUTHOR}${RESET}"
    echo -e "  ${BOLD}${CYAN}Repo${RESET}     ${BLUE}${REPO_HTTPS}${RESET}"
    echo ""
}

# ============================================================
# CLI helpers
# ============================================================
show_help() {
    show_banner
    echo -e "${CLI_HELP_USAGE}"
    echo ""
    echo -e "${CLI_HELP_CMDS}"
    echo -e "${CLI_HELP_MENU}"
    echo -e "${CLI_HELP_HELP}"
    echo -e "${CLI_HELP_VERSION}"
    echo -e "${CLI_HELP_UPDATE}"
}
show_version() { echo "xynrin v${CURRENT_VERSION}"; }

# ============================================================
# 纯 bash 兜底菜单（Rust 二进制缺失时使用）
# Pure-bash fallback menu (when Rust binary is missing)
# ============================================================
fallback_menu() {
    while true; do
        local options=(
            "1) ${OPT_UPDATE}"
            "2) ${OPT_PROOT_INSTALL}"
            "3) ${OPT_PROOT_BACKUP}"
            "4) ${OPT_X11}"
            "5) ${OPT_SSH}"
            "6) ${OPT_CLEANUP}"
            "7) ${OPT_BOOT}"
            "8) ${OPT_SYSTEM_INFO}"
            "9) ${OPT_MIRROR}"
            "10) ${OPT_LANGUAGE}"
            "11) ${OPT_BEAUTIFY}"
            "12) ${OPT_EXIT}"
        )
        echo ""
        local picked
        if command -v fzf &> /dev/null; then
            picked="$(printf '%s\n' "${options[@]}" | fzf --height=50% --reverse --no-info --border=rounded \
                --prompt="${MENU_TITLE} > ")" || picked="12"
        else
            echo -e "${BOLD}${CYAN}=== ${MENU_TITLE} ===${RESET}"
            printf '  %s\n' "${options[@]}"
            echo -n "> "
            read -r raw
            picked="${raw}) "
        fi
        case "$picked" in
            1*)  load_module update;   update_check_action; update_apply_action ;;
            2*)  load_module proot;    proot_install_action ;;
            3*)  load_module backup;   backup_action ;;
            4*)  load_module x11;      x11_action ;;
            5*)  load_module ssh;      ssh_action ;;
            6*)  load_module cleanup;  cleanup_action ;;
            7*)  load_module boot;     boot_action ;;
            8*)  load_module sysinfo;  sysinfo_action ;;
            9*)  load_module mirror;   mirror_action ;;
            10*) load_module language; language_action ;;
            11*) load_module beautify; beautify_action ;;
            12*|0*|"") echo -e "${GREEN}${MSG_GOODBYE}${RESET}"; exit 0 ;;
            *) echo -e "${RED}${MSG_INVALID_CHOICE}${RESET}" ;;
        esac
        echo ""
        echo -n "${MSG_PRESS_ENTER}"
        read -r _ || true
    done
}

# ============================================================
# Entry / 入口
# ============================================================
main() {
    load_language "$(get_language_pref)"

    case "${1:-menu}" in
        help|-h|--help)        show_help ;;
        version|-v|--version)  show_version ;;
        update|-u|--update)
            load_module update
            update_check_action && update_apply_action
            ;;
        sysinfo)               load_module sysinfo;  sysinfo_action ;;

        # Rust TUI 调用的子命令分发（v3.0.0 兼容）
        # Subcommand dispatch from Rust TUI (v3.0.0 compatible)
        --menu-update)         load_module update;   update_check_action; update_apply_action ;;
        --menu-update-check)   load_module update;   update_check_action ;;
        --menu-update-apply)   load_module update;   update_apply_action ;;
        --menu-proot-install)  ensure_fzf; load_module proot;    proot_install_action ;;
        --menu-proot-backup)   ensure_fzf; load_module backup;   backup_action ;;
        --menu-x11)            ensure_fzf; load_module x11;      x11_action ;;
        --menu-ssh)            ensure_fzf; load_module ssh;      ssh_action ;;
        --menu-cleanup)        ensure_fzf; load_module cleanup;  cleanup_action ;;
        --menu-boot)           ensure_fzf; load_module boot;     boot_action ;;
        --menu-system-info)    load_module sysinfo;  sysinfo_action ;;
        --menu-mirror)         ensure_fzf; load_module mirror;   mirror_action ;;
        --menu-language)       ensure_fzf; load_module language; language_action ;;
        --menu-beautify)       ensure_fzf; load_module beautify; beautify_action ;;
        --menu-bootstrap)      load_module bootstrap; bootstrap_action ;;

        menu|"")
            ensure_fzf
            show_banner
            echo -e "${BOLD}${MSG_WELCOME}${RESET}"
            fallback_menu
            ;;
        *)
            echo -e "${RED}Unknown command: $1${RESET}"
            echo ""
            show_help
            exit 1
            ;;
    esac
}

main "$@"
