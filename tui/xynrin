set -uo pipefail   # 不用 -e：交互式 TUI 需要容忍单步失败 / no -e: tolerate step failures in interactive TUI

# ============================================================
# 路径解析（跟随符号链接）/ Path resolution (follow symlinks)
# ============================================================
REAL_SCRIPT="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$REAL_SCRIPT")" &> /dev/null && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

VERSION_FILE="$PROJECT_ROOT/scripts/version"
LANG_DIR="$SCRIPT_DIR/lang"
INSTALL_SCRIPT="$PROJECT_ROOT/install.sh"
ALIASES_FILE="$PROJECT_ROOT/.aliases"

REPO_HTTPS="https://github.com/Xynrin/termux-tools"
REPO_RAW="https://raw.githubusercontent.com/Xynrin/termux-tools/main"

CURRENT_VERSION="$(cat "$VERSION_FILE" 2>/dev/null || echo "unknown")"
AUTHOR="Xynrin"

# ============================================================
# 颜色 / Colors
# ============================================================
RED='\e[31m'; GREEN='\e[32m'; YELLOW='\e[33m'; BLUE='\e[34m'
MAGENTA='\e[35m'; CYAN='\e[36m'; ORANGE='\e[38;5;202m'
BOLD='\e[1m'; RESET='\e[0m'

# ============================================================
# 语言加载 / Language loading
# ============================================================
LANG_PREF_FILE="$PROJECT_ROOT/.lang_pref"

detect_language() {
    local lang_env="${LANG:-${LC_ALL:-en_US}}"
    if [[ "$lang_env" == *zh* ]] || [[ "$lang_env" == *CN* ]] || [[ "$lang_env" == *TW* ]]; then
        echo "zh"
    else
        echo "en"
    fi
}

get_language_pref() {
    [[ -f "$LANG_PREF_FILE" ]] && cat "$LANG_PREF_FILE" || detect_language
}

load_language() {
    local code="${1:-$(detect_language)}"
    local file="$LANG_DIR/${code}.sh"
    [[ -f "$file" ]] && source "$file" || source "$LANG_DIR/en.sh"
}

# ============================================================
# fzf 自动安装 / Auto-install fzf
# ============================================================
ensure_fzf() {
    if command -v fzf &> /dev/null; then
        return 0
    fi
    echo -e "${YELLOW}${MSG_FZF_INSTALLING:-Installing fzf...}${RESET}"
    if command -v pkg &> /dev/null; then
        pkg install -y fzf || return 1
    elif command -v apt &> /dev/null; then
        apt install -y fzf || return 1
    else
        return 1
    fi
}

# fzf 选择封装：返回选中行（去除前缀编号）
# fzf wrapper: returns selected line (without leading index)
# 用法 / Usage: fzf_pick "Title" "1) Option A" "2) Option B" ...
fzf_pick() {
    local title="$1"; shift
    printf '%s\n' "$@" | fzf \
        --ansi \
        --prompt="$title > " \
        --height=40% \
        --reverse \
        --no-info \
        --border=rounded \
        --color='border:cyan,prompt:yellow,pointer:green,marker:green'
}

# ============================================================
# Logo / Banner
# ============================================================
