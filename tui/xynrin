# 检测已有美化标记 / Detect existing beautify marker
beautify_detect() {
    local found=()
    [[ -f "$HOME/.termux/colors.properties" ]] && \
        grep -q "$BEAUTIFY_MARKER" "$HOME/.termux/colors.properties" 2>/dev/null && \
        found+=("colors.properties")
    [[ -f "$HOME/.termux/termux.properties" ]] && \
        grep -q "$BEAUTIFY_MARKER" "$HOME/.termux/termux.properties" 2>/dev/null && \
        found+=("termux.properties")
    [[ -f "$HOME/.config/starship.toml" ]] && \
        grep -q "$BEAUTIFY_MARKER" "$HOME/.config/starship.toml" 2>/dev/null && \
        found+=("starship.toml")
    [[ -f "$HOME/.bashrc" ]] && \
        grep -q "$BEAUTIFY_MARKER" "$HOME/.bashrc" 2>/dev/null && \
        found+=(".bashrc(starship)")
    [[ -f "$HOME/.termux/font.ttf" ]] && found+=("font.ttf")
    printf '%s\n' "${found[@]}"
}

beautify_uninstall() {
    local detected
    detected="$(beautify_detect)"

    if [[ -z "$detected" ]]; then
        echo -e "${YELLOW}${MSG_BEAUTIFY_NONE_FOUND}${RESET}"
        return 0
    fi

    echo -e "${CYAN}${MSG_BEAUTIFY_DETECTED}:${RESET}"
    while IFS= read -r f; do
        echo -e "  - ${YELLOW}${f}${RESET}"
    done <<< "$detected"
    echo ""

    # 删除带标记的文件 / Remove marker-tagged files
    [[ -f "$HOME/.termux/colors.properties" ]] && \
        grep -q "$BEAUTIFY_MARKER" "$HOME/.termux/colors.properties" 2>/dev/null && \
        rm -f "$HOME/.termux/colors.properties"
    [[ -f "$HOME/.termux/termux.properties" ]] && \
        grep -q "$BEAUTIFY_MARKER" "$HOME/.termux/termux.properties" 2>/dev/null && \
        rm -f "$HOME/.termux/termux.properties"
    [[ -f "$HOME/.config/starship.toml" ]] && \
        grep -q "$BEAUTIFY_MARKER" "$HOME/.config/starship.toml" 2>/dev/null && \
        rm -f "$HOME/.config/starship.toml"
    rm -f "$HOME/.termux/font.ttf"

    # 移除 .bashrc 中的 starship 行（含标记块）
    # Strip the marker block from .bashrc
    if [[ -f "$HOME/.bashrc" ]] && grep -q "$BEAUTIFY_MARKER" "$HOME/.bashrc" 2>/dev/null; then
        sed -i '/# xynrin-beautify/,+1d' "$HOME/.bashrc"
    fi

    command -v termux-reload-settings &> /dev/null && termux-reload-settings || true

    echo -e "${GREEN}${MSG_BEAUTIFY_REMOVED}${RESET}"
    echo -e "${YELLOW}${MSG_ALIAS_RESTART_HINT}${RESET}"
}

beautify_menu() {
    local options=(
        "1) ${MSG_BEAUTIFY_DRACULA}"
        "2) ${MSG_BEAUTIFY_CATPPUCCIN}"
        "3) ${MSG_BEAUTIFY_NORD}"
        "4) ${MSG_BEAUTIFY_UNINSTALL}"
        "0) ${OPT_BACK}"
    )

    local picked
    if command -v fzf &> /dev/null; then
        picked="$(fzf_pick "${MSG_BEAUTIFY_TITLE}" "${options[@]}")" || return 0
    else
        echo -e "${BOLD}${CYAN}${MSG_BEAUTIFY_TITLE}${RESET}"
        printf '  %s\n' "${options[@]}"
        echo -n "> "
        read -r raw
        picked="${raw}) "
    fi

    case "$picked" in
        1*) beautify_apply "dracula" ;;
        2*) beautify_apply "catppuccin" ;;
        3*) beautify_apply "nord" ;;
        4*) beautify_uninstall ;;
        0*|"") return 0 ;;
        *) echo -e "${RED}${MSG_INVALID_CHOICE}${RESET}" ;;
    esac
}

# ============================================================
# 主菜单 / Main menu (fzf-driven)
# ============================================================
show_menu() {
    while true; do
        # 每轮重新构造，使切换语言后菜单文案立即刷新
        # Rebuild each loop so menu text refreshes after language switch
        local options=(
            "1) ${OPT_UPDATE}"
            "2) ${OPT_PROOT_INSTALL}"
            "3) ${OPT_LIST_ALIASES}"
            "4) ${OPT_SYSTEM_INFO}"
            "5) ${OPT_MIRROR}"
            "6) ${OPT_LANGUAGE}"
            "7) ${OPT_BEAUTIFY}"
            "8) ${OPT_EXIT}"
        )

        echo ""
        local picked
        if command -v fzf &> /dev/null; then
            picked="$(fzf_pick "${MENU_TITLE}" "${options[@]}")" || picked="8"
        else
            echo -e "${BOLD}${CYAN}=== ${MENU_TITLE} ===${RESET}"
            printf '  %s\n' "${options[@]}"
            echo -n "> "
            read -r raw
            picked="${raw}) "
        fi

        case "$picked" in
            1*) do_update ;;
            2*) proot_install ;;
            3*) list_aliases ;;
            4*) show_system_info ;;
            5*) configure_mirror ;;
            6*) change_language ;;
            7*) beautify_menu ;;
            8*|0*|"") echo -e "${GREEN}${MSG_GOODBYE}${RESET}"; exit 0 ;;
            *) echo -e "${RED}${MSG_INVALID_CHOICE}${RESET}" ;;
        esac

        echo ""
        echo -n "${MSG_PRESS_ENTER}"
        read -r _ || true
    done
}

# ============================================================
# CLI / CLI commands
# ============================================================
show_help() {
    show_banner
    echo -e "${CLI_HELP_USAGE}"
    echo ""
    echo -e "${CLI_HELP_CMDS}"
    echo -e "${CLI_HELP_MENU}"
    echo -e "${CLI_HELP_HELP}"
    echo -e "${CLI_HELP_VERSION}"
    echo -e "${CLI_HELP_UPDATE}"
}

show_version() { echo "xynrin v${CURRENT_VERSION}"; }

# ============================================================
# Entry / 入口
# ============================================================
main() {
    load_language "$(get_language_pref)"

    case "${1:-menu}" in
        help|-h|--help)        show_help ;;
        version|-v|--version)  show_version ;;
        update|-u|--update)    do_update ;;
        # Rust TUI 调用的子命令分发 / Sub-commands invoked from the Rust TUI
        --menu-update)         do_update ;;
        --menu-proot-install)  ensure_fzf || true; proot_install ;;
        --menu-list-aliases)   list_aliases ;;
        --menu-system-info)    show_system_info ;;
        --menu-mirror)         ensure_fzf || true; configure_mirror ;;
        --menu-language)       ensure_fzf || true; change_language ;;
        --menu-beautify)       ensure_fzf || true; beautify_menu ;;
        menu|"")
            ensure_fzf || echo -e "${YELLOW}${MSG_FZF_FALLBACK:-fzf unavailable, using fallback prompt}${RESET}"
            show_banner
            echo -e "${BOLD}${MSG_WELCOME}${RESET}"
            show_menu
            ;;
        *)
            echo -e "${RED}Unknown command: $1${RESET}"
            echo ""
            show_help
            exit 1
            ;;
    esac
}

main "$@"
