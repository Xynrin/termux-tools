# 显示帮助信息
# Show help text
show_help() {
    # 标题：粗体橙色 + 版本号
    # Title: bold orange + version
    echo -e "${BOLD}${ORANGE}${CLI_HELP_TITLE}${RESET} v${CURRENT_VERSION}"
    echo ""
    echo -e "${CLI_HELP_USAGE}"
    echo ""
    echo -e "${CLI_HELP_CMDS}"
    echo -e "${CLI_HELP_MENU}"
    echo -e "${CLI_HELP_HELP}"
    echo -e "${CLI_HELP_VERSION}"
    echo -e "${CLI_HELP_UPDATE}"
}

# 显示版本号
# Show version
show_version() {
    echo "termux-tools v${CURRENT_VERSION}"
}

# ============================================================
# 主入口函数
# Main entry function
# ============================================================
main() {
    # 加载语言（优先用户偏好，否则自动检测）
    # Load language (user preference, otherwise auto-detect)
    load_language "$(get_language_pref)"

    # 解析第一个 CLI 参数；为空时默认 menu
    # Parse first CLI arg; default to "menu" when empty
    #   ${1:-menu}: 取 $1，未定义则用 menu / use $1 or "menu" if unset
    case "${1:-menu}" in
        # help / -h / --help 都打印帮助
        # help / -h / --help all print help
        help|-h|--help)
            show_help
            ;;
        # version / -v / --version 都打印版本
        # version / -v / --version all print version
        version|-v|--version)
            show_version
            ;;
        # update / -u / --update 都执行更新
        # update / -u / --update all run update
        update|-u|--update)
            do_update
            ;;
        # menu 或无参数时进入 TUI
        # menu or no arg enters TUI
        menu|"")
            show_logo                                              # 显示 LOGO / show logo
            echo -e "${BOLD}${MSG_WELCOME}${RESET}"                # 欢迎信息 / welcome
            echo -e "${MSG_CURRENT_VERSION}: ${GREEN}${CURRENT_VERSION}${RESET}"   # 版本 / version
            show_menu                                              # 进入菜单 / enter menu
            ;;
        # 未知命令打印错误并显示帮助
        # Unknown command prints error and help
        *)
            echo -e "${RED}Unknown command: $1${RESET}"
            echo ""
            show_help
            exit 1   # 返回错误码 / return error code
            ;;
    esac
}

# 调用 main，把所有命令行参数传入
# Invoke main, passing all CLI args
#   "$@": 完整传递参数（保留引号）/ pass args verbatim (preserve quoting)
main "$@"
