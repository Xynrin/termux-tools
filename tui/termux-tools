# set 命令设置 shell 选项 / set command configures shell options
#   -e: 任何命令失败立即退出 / exit immediately if any command fails
#   -u: 使用未定义变量时报错 / treat unset variables as error
#   -o pipefail: 管道中任何命令失败则整条管道失败 / pipeline fails if any command in it fails
set -euo pipefail

# ============================================================
# 路径与版本变量定义
# Path and version variables
# ============================================================

# 获取当前脚本所在的绝对路径
# Get absolute path of the directory containing this script
#   ${BASH_SOURCE[0]}: 当前脚本路径 / current script path
#   dirname: 提取目录部分 / extract directory part
#   cd ... && pwd: 切换并打印绝对路径 / cd into it and print absolute path
#   &> /dev/null: 屏蔽所有输出 / suppress all output
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" &> /dev/null && pwd)"

# 项目根目录 = 脚本目录的上一级（tui/ 的上一级）
# Project root = parent of script directory (parent of tui/)
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# 版本文件路径，用于本地版本读取与远程对比
# Path to version file, used for local read and remote comparison
VERSION_FILE="$PROJECT_ROOT/scripts/version"

# 语言包目录，存放 zh.sh 和 en.sh
# Language pack directory containing zh.sh and en.sh
LANG_DIR="$SCRIPT_DIR/lang"

# 远程仓库 raw 内容地址，用于检查远程版本
# Remote repo raw content URL, used to fetch remote version
REPO_URL="https://raw.githubusercontent.com/Xynrin/termux-tools/main"

# 读取当前版本号；若文件不存在则显示 unknown
# Read current version; show "unknown" if file is missing
#   2>/dev/null: 屏蔽错误输出 / suppress error output
#   ||: 前一个命令失败时执行后续 / run next command if previous fails
CURRENT_VERSION="$(cat "$VERSION_FILE" 2>/dev/null || echo "unknown")"

# ============================================================
# ANSI 终端颜色定义
# ANSI terminal color codes
# \e[ 是转义序列起始 / \e[ is escape sequence prefix
# 数字代码后接 m 表示颜色 / number followed by m sets color
# ============================================================
RED='\e[31m'        # 红色：错误信息 / Red: error messages
GREEN='\e[32m'      # 绿色：成功信息 / Green: success messages
YELLOW='\e[33m'     # 黄色：警告信息 / Yellow: warnings
BLUE='\e[34m'       # 蓝色：链接/路径 / Blue: links/paths
MAGENTA='\e[35m'    # 品红色：强调 / Magenta: emphasis
CYAN='\e[36m'       # 青色：提示信息 / Cyan: info
ORANGE='\e[38;5;202m'  # 橙色：256 色模式中的火焰橙 / Orange: flame orange in 256-color mode
BOLD='\e[1m'        # 加粗 / Bold
RESET='\e[0m'       # 重置所有样式 / Reset all styles

# ============================================================
# 语言检测与加载
# Language detection and loading
# ============================================================

# 自动检测系统语言
# Auto-detect system language
detect_language() {
    # 读取 LANG 环境变量；若为空则用 LC_ALL；都为空则用 en_US
    # Read LANG env var; fallback to LC_ALL; final fallback en_US
    #   ${LANG:-${LC_ALL:-en_US}}: 嵌套默认值 / nested default values
    local lang_env="${LANG:-${LC_ALL:-en_US}}"

    # 检查变量中是否包含 zh、CN、TW（中文区域标识）
    # Check if variable contains zh, CN, or TW (Chinese locale identifiers)
    #   [[ ... == *pattern* ]]: 通配符匹配 / glob pattern matching
    if [[ "$lang_env" == *zh* ]] || [[ "$lang_env" == *CN* ]] || [[ "$lang_env" == *TW* ]]; then
        echo "zh"   # 输出 zh 表示中文 / output "zh" for Chinese
    else
        echo "en"   # 否则输出 en 表示英文 / otherwise "en" for English
    fi
}

# 加载指定语言包
# Load specified language pack
load_language() {
    # 第一个参数为语言代码，未提供时调用 detect_language 自动检测
    # First arg is language code; if missing, call detect_language
    local lang_code="${1:-$(detect_language)}"

    # 拼接语言文件路径，例如 lang/zh.sh
    # Build language file path, e.g. lang/zh.sh
    local lang_file="$LANG_DIR/${lang_code}.sh"

    # 如果文件存在则加载，否则回退到英文
    # Source the file if it exists, otherwise fall back to English
    #   -f: 测试文件是否存在 / test if file exists
    #   source: 在当前 shell 中执行脚本 / execute script in current shell
    if [[ -f "$lang_file" ]]; then
        source "$lang_file"
    else
        source "$LANG_DIR/en.sh"
    fi
}

# 语言偏好持久化文件，保存用户选择的语言
# Language preference file, persists user's language choice
LANG_PREF_FILE="$PROJECT_ROOT/.lang_pref"

# 保存语言偏好到文件
# Save language preference to file
save_language_pref() {
    # $1 是函数第一个参数，> 表示重定向写入（覆盖）
    # $1 is first function arg, > redirects (overwrites file)
    echo "$1" > "$LANG_PREF_FILE"
}

# 读取语言偏好；若文件不存在则自动检测
# Read language preference; auto-detect if file missing
get_language_pref() {
    if [[ -f "$LANG_PREF_FILE" ]]; then
        cat "$LANG_PREF_FILE"   # 输出文件内容 / output file content
    else
        detect_language          # 调用自动检测 / call auto-detection
    fi
}

