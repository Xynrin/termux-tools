#!/usr/bin/env bash
#
# 旧版兼容垫片 / Legacy compatibility shim
#
# 这个脚本仅为已通过 v1.x 安装的用户保留。它会自动拉取最新代码并迁移
# 到新命令 xynrin。新用户请直接使用 xynrin。
#
# Kept only for users who installed v1.x. It pulls the latest code and
# migrates them to the new xynrin command. New installs should use xynrin.
#
set -euo pipefail

REAL_SCRIPT="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$REAL_SCRIPT")" &> /dev/null && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

YELLOW='\e[33m'
CYAN='\e[36m'
GREEN='\e[32m'
RESET='\e[0m'

echo -e "${YELLOW}termux-tools 已重命名为 xynrin。正在自动迁移...${RESET}"
echo -e "${YELLOW}termux-tools has been renamed to xynrin. Migrating...${RESET}"
echo ""

# 拉取最新代码 / Pull latest code
if [[ -d "$PROJECT_ROOT/.git" ]] && command -v git &> /dev/null; then
    echo -e "${CYAN}git pull origin main${RESET}"
    ( cd "$PROJECT_ROOT" && git pull --ff-only origin main )
fi

# 应用迁移（重建 xynrin 软链，移除旧 termux-tools）
# Apply migration (rebuild xynrin symlink, remove old termux-tools)
bash "$PROJECT_ROOT/install.sh" --upgrade

echo ""
echo -e "${GREEN}迁移完成。正在启动 xynrin...${RESET}"
echo -e "${GREEN}Migration done. Launching xynrin...${RESET}"
echo ""

# 启动新命令并把所有参数透传给它 / Launch new command with all args passed through
exec "$PREFIX/bin/xynrin" "$@"
