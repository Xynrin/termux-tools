# ============================================================
# 更新逻辑
# Update logic
# ============================================================

# 检查更新（仅检查不执行）
# Check for updates (check only, no install)
check_update() {
    # 显示"正在检查更新"提示
    # Display "checking for update" message
    echo -e "${CYAN}${MSG_UPDATING}${RESET}"

    # 声明局部变量保存远程版本号
    # Declare local var to store remote version
    local remote_version

    # curl 下载远程版本文件内容
    # curl downloads the remote version file
    #   -s: 静默模式 / silent mode
    #   -L: 跟随重定向 / follow redirects
    #   2>/dev/null: 隐藏错误 / hide errors
    #   || echo "": 失败时输出空字符串 / output empty on failure
    remote_version="$(curl -sL "${REPO_URL}/scripts/version" 2>/dev/null || echo "")"

    # 远程版本为空说明网络失败
    # Empty remote version means network failure
    #   -z: 测试字符串是否为空 / test if string is empty
    if [[ -z "$remote_version" ]]; then
        echo -e "${RED}${MSG_UPDATE_FAILED}${RESET}"
        return 1   # 返回非零表示失败 / return non-zero on failure
    fi

    # 去除版本号中的所有空白字符（含换行）
    # Strip all whitespace from version string (incl. newlines)
    #   tr -d: 删除指定字符 / delete specified chars
    #   [:space:]: 所有空白字符 / all whitespace chars
    remote_version="$(echo "$remote_version" | tr -d '[:space:]')"

    # 显示当前版本与最新版本
    # Display current and latest versions
    echo -e "${MSG_CURRENT_VERSION}: ${GREEN}${CURRENT_VERSION}${RESET}"
    echo -e "${MSG_LATEST_VERSION}: ${GREEN}${remote_version}${RESET}"

    # 比较版本号
    # Compare versions
    if [[ "$CURRENT_VERSION" == "$remote_version" ]]; then
        echo -e "${GREEN}${MSG_ALREADY_LATEST}${RESET}"
        return 0   # 已是最新 / already latest
    fi

    # 提示有新版本可用
    # Notify update is available
    echo -e "${YELLOW}${MSG_UPDATE_AVAILABLE}${RESET} (${CURRENT_VERSION} -> ${remote_version})"
    return 0
}

# 执行更新（实际拉取代码）
# Perform actual update (pull code)
do_update() {
    echo -e "${CYAN}${MSG_UPDATING}${RESET}"

    local remote_version
    remote_version="$(curl -sL "${REPO_URL}/scripts/version" 2>/dev/null || echo "")"

    if [[ -z "$remote_version" ]]; then
        echo -e "${RED}${MSG_UPDATE_FAILED}${RESET}"
        return 1
    fi

    remote_version="$(echo "$remote_version" | tr -d '[:space:]')"

    # 已是最新版本则直接返回
    # Return early if already up to date
    if [[ "$CURRENT_VERSION" == "$remote_version" ]]; then
        echo -e "${GREEN}${MSG_ALREADY_LATEST}${RESET}"
        return 0
    fi

    echo -e "${MSG_UPDATE_AVAILABLE} (${CURRENT_VERSION} -> ${remote_version})"

    # 检查 git 命令是否可用且项目是 git 仓库
    # Check if git is available and project is a git repo
    #   command -v: 查找命令是否存在 / check if command exists
    #   -d: 测试目录是否存在 / test if directory exists
    if command -v git &> /dev/null && [[ -d "$PROJECT_ROOT/.git" ]]; then
        # 切换到项目根目录执行 git pull
        # Cd to project root and run git pull
        cd "$PROJECT_ROOT"
        # 2>&1: 错误输出合并到标准输出 / merge stderr to stdout
        git pull origin main 2>&1
        echo -e "${GREEN}${MSG_UPDATE_DONE}${RESET}"
    else
        # git 不可用或不是仓库 / git unavailable or not a repo
        echo -e "${RED}${MSG_UPDATE_FAILED}${RESET}"
        return 1
    fi
}

# ============================================================
# proot 功能
# proot features
# ============================================================

# 安装 proot 发行版
# Install a proot distro
proot_install() {
    # 提示用户输入发行版名称
    # Prompt user to enter distro name
    echo -e "${CYAN}${MSG_PROOT_DISTRO_NAME}${RESET}"
    echo -e "${YELLOW}${MSG_PROOT_DISTRO_EXAMPLE}${RESET}"

    # -n: 不换行（提示符在同一行）/ no trailing newline
    echo -n "> "

    # 读取用户输入到 distro_name 变量
    # Read user input into distro_name
    #   -r: 不解析反斜杠 / don't interpret backslashes
    read -r distro_name

    # 输入为空时报错并返回
    # Error and return if input is empty
    if [[ -z "$distro_name" ]]; then
        echo -e "${RED}${MSG_INVALID_CHOICE}${RESET}"
        return 1
    fi

    # 显示正在安装的提示
    # Show installing message
    echo -e "${CYAN}${MSG_PROOT_INSTALLING} ${distro_name}...${RESET}"

    # 调用 proot-distro install 安装；判断返回值
    # Call proot-distro install; check return code
    #   if 直接判断命令成功与否 / if directly checks command success
    if proot-distro install "$distro_name"; then
        echo -e "${GREEN}${MSG_PROOT_INSTALL_DONE}${RESET}"
    else
        echo -e "${RED}${MSG_PROOT_INSTALL_FAILED}${RESET}"
    fi
}

# 登录已安装的 proot 发行版
# Login to an installed proot distro
proot_login() {
    # proot-distro 命令不存在则退出
    # Exit if proot-distro is not installed
    #   !: 取反 / negate
    if ! command -v proot-distro &> /dev/null; then
        echo -e "${RED}proot-distro not found${RESET}"
        return 1
    fi

    # 获取已安装的发行版列表
    # Get list of installed distros
    local installed
    #   grep -E '^[a-z]': 只保留以小写字母开头的行（发行版名）
    #   grep -E '^[a-z]': keep only lines starting with lowercase letter (distro names)
    #   awk '{print $1}': 取每行第一个字段 / extract first field of each line
    installed="$(proot-distro list --installed 2>/dev/null | grep -E '^[a-z]' | awk '{print $1}')"

    # 没有已安装发行版则提示并返回
    # Notify and return if no distros installed
    if [[ -z "$installed" ]]; then
        echo -e "${YELLOW}${MSG_PROOT_NOT_INSTALLED}${RESET}"
        return 1
    fi

    # 显示选择提示
    # Show selection prompt
    echo -e "${CYAN}${MSG_PROOT_SELECT}:${RESET}"

    # 声明数组保存发行版列表
    # Declare array to hold distro list
    #   -a: 索引数组 / indexed array
    local -a distros
    local i=1   # 序号计数器 / index counter

    # 逐行读取并加入数组并打印
    # Read line by line, add to array, print
    #   IFS=: 不修改字段分隔符 / preserve original IFS
    #   <<<: here-string 把字符串当输入 / here-string as input
    while IFS= read -r line; do
        distros+=("$line")   # 添加到数组末尾 / append to array
        echo -e "  ${GREEN}${i})${RESET} ${line}"
        ((i++))   # 计数器 +1 / increment counter
    done <<< "$installed"

    echo -n "> "
    read -r choice

    # 验证输入是合法序号
    # Validate input is a valid index
    #   =~: 正则匹配 / regex match
    #   ^[0-9]+$: 只匹配纯数字 / digits only
    #   #数组: 数组长度 / array length
    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#distros[@]} )); then
        # 数组索引从 0 开始，所以减 1
        # Array index is 0-based, subtract 1
        local selected="${distros[$((choice - 1))]}"

        # 显示登录提示后调用 proot-distro login
        # Show hint then call proot-distro login
        echo -e "${YELLOW}${MSG_PROOT_LOGIN_HINT}${RESET}"
        proot-distro login "$selected"
    else
        echo -e "${RED}${MSG_INVALID_CHOICE}${RESET}"
    fi
}

# ============================================================
# 系统信息
# System info
# ============================================================
show_system_info() {
    # 标题：粗体青色
    # Title: bold cyan
    echo -e "${BOLD}${CYAN}${MSG_SYSTEM_INFO}${RESET}"

    # uname -o: 操作系统名称（GNU/Linux 等）/ OS name
    # 失败则使用 uname -s（内核名）/ fallback to kernel name
    echo -e "  ${GREEN}${MSG_OS}:${RESET}        $(uname -o 2>/dev/null || uname -s)"

    # uname -m: 机器架构（x86_64/aarch64 等）/ machine architecture
    echo -e "  ${GREEN}${MSG_ARCH}:${RESET}        $(uname -m)"

    # uname -r: 内核版本 / kernel release
    echo -e "  ${GREEN}${MSG_KERNEL}:${RESET}      $(uname -r)"

    # $SHELL: 当前 shell 路径 / current shell path
    echo -e "  ${GREEN}${MSG_SHELL}:${RESET}       $SHELL"

    # 仅在 Termux 环境下显示 Termux 版本
    # Show Termux version only if running in Termux
    #   -n: 测试非空 / test non-empty
    #   ${VAR:-}: 默认空避免 set -u 报错 / default to empty under set -u
    if [[ -n "${TERMUX_VERSION:-}" ]]; then
        echo -e "  ${GREEN}${MSG_TERMUX_VERSION}:${RESET} ${TERMUX_VERSION}"
    fi

    # 如有 fastfetch 则展示更详细的系统信息
    # Run fastfetch for richer system info if installed
    if command -v fastfetch &> /dev/null; then
        echo ""
        fastfetch
    fi
}

# ============================================================
# 语言切换
# Language switching
# ============================================================
change_language() {
    # 显示语言选择菜单
    # Show language selection menu
    echo -e "${BOLD}${LANG_TITLE}${RESET}"
    echo -e "  ${GREEN}1)${RESET} ${LANG_ZH}"
    echo -e "  ${GREEN}2)${RESET} ${LANG_EN}"
    echo -n "> "
    read -r choice

    # case 多分支判断
    # case statement for multi-branch matching
    case "$choice" in
        # 1: 保存中文偏好并立即切换
        # 1: save Chinese preference and switch immediately
        1) save_language_pref "zh"; load_language "zh" ;;
        # 2: 保存英文偏好并立即切换
        # 2: save English preference and switch
        2) save_language_pref "en"; load_language "en" ;;
        # *: 任何其他输入算作无效
        # *: any other input is invalid
        *) echo -e "${RED}${MSG_INVALID_CHOICE}${RESET}" ;;
    esac
}

# ============================================================
# TUI 主菜单循环
# TUI main menu loop
# ============================================================
show_menu() {
    # 无限循环直到用户选择退出
    # Infinite loop until user chooses to exit
    while true; do
        echo ""

        # 输出菜单标题与所有选项
        # Print menu title and all options
        echo -e "${BOLD}${CYAN}=== ${MENU_TITLE} ===${RESET}"
        echo -e "  ${GREEN}1)${RESET} ${OPT_UPDATE}"
        echo -e "  ${GREEN}2)${RESET} ${OPT_PROOT_INSTALL}"
        echo -e "  ${GREEN}3)${RESET} ${OPT_PROOT_LOGIN}"
        echo -e "  ${GREEN}4)${RESET} ${OPT_SYSTEM_INFO}"
        echo -e "  ${GREEN}5)${RESET} ${OPT_LANGUAGE}"
        echo -e "  ${GREEN}0)${RESET} ${OPT_EXIT}"
        echo ""
        echo -n "> "
        read -r choice

        # 根据选择调用对应函数
        # Dispatch to function based on choice
        case "$choice" in
            1) do_update ;;             # 更新 / update
            2) proot_install ;;         # 安装发行版 / install distro
            3) proot_login ;;           # 登录发行版 / login distro
            4) show_system_info ;;      # 系统信息 / system info
            5) change_language ;;       # 切换语言 / change language
            # 0/q/Q 都视为退出 / 0/q/Q all treated as exit
            0|q|Q) echo -e "${GREEN}${MSG_GOODBYE}${RESET}"; exit 0 ;;
            *) echo -e "${RED}${MSG_INVALID_CHOICE}${RESET}" ;;
        esac

        # 等待用户按 Enter 后再显示下一轮菜单
        # Wait for Enter before showing menu again
        echo ""
        echo -n "${MSG_PRESS_ENTER}"
        # _ 表示丢弃输入 / _ discards the input
        read -r _
    done
}

