#!/usr/bin/env bash
# 使用 env 查找 bash，提高跨平台兼容性
# Use env to locate bash for better cross-platform compatibility
#
# ============================================================
# termux-tools TUI 安装脚本
# termux-tools TUI installation script
#
# 功能 / Purpose:
#   将 tui/termux-tools 主程序复制到 ~/.local/bin/
#   并配置 PATH 使其可作为命令执行
#   Copy tui/termux-tools to ~/.local/bin/
#   and configure PATH so it runs as a command
#
# 使用场景 / Use case:
#   独立运行此脚本以仅安装 TUI 工具
#   （不安装 Termux 依赖，适合在已安装环境的设备上重新部署）
#   Run standalone to install only the TUI tool
#   (without Termux deps; useful for redeploying on prepared devices)
# ============================================================

# 启用严格模式
# Enable strict mode
#   -e: 命令失败立即退出 / exit on failure
#   -u: 未定义变量报错 / error on unset
#   -o pipefail: 管道任何命令失败则失败 / pipeline fails if any cmd fails
set -euo pipefail

# ============================================================
# 路径变量
# Path variables
# ============================================================

# 获取本脚本所在目录的绝对路径
# Get absolute path of this script's directory
#   ${BASH_SOURCE[0]}: 当前脚本路径 / current script path
#   dirname: 取目录部分 / extract directory
#   cd ... && pwd: 切换并打印绝对路径 / cd then print absolute path
#   &> /dev/null: 屏蔽全部输出 / suppress all output
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" &> /dev/null && pwd)"

# 项目根目录 = 脚本目录的上一级（install-scripts 的上一级）
# Project root = parent of script dir (parent of install-scripts/)
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# 源文件：项目中的主 TUI 脚本
# Source: main TUI script in the project
SOURCE_FILE="$PROJECT_ROOT/tui/termux-tools"

# 目标目录：用户级可执行文件目录
# Target dir: user-level executable directory
TARGET_DIR="$HOME/.local/bin"

# 目标完整路径
# Full target path
TARGET_FILE="$TARGET_DIR/termux-tools"

# ============================================================
# 检查源文件
# Check source file
# ============================================================

# 测试源文件是否存在
# Test if source file exists
#   ! -f: 文件不存在或不是普通文件 / file missing or not regular file
if [[ ! -f "$SOURCE_FILE" ]]; then
    # 双语错误信息
    # Bilingual error message
    echo "错误：找不到源文件 $SOURCE_FILE"
    echo "Error: Source file not found at $SOURCE_FILE"
    exit 1   # 非零退出码 / non-zero exit code
fi

# ============================================================
# 创建目标目录
# Create target directory
# ============================================================

# mkdir 创建目录 / mkdir creates directory
#   -p: 一并创建上级目录，已存在不报错
#   -p: create parents, no error if exists
mkdir -p "$TARGET_DIR"

# ============================================================
# 安装文件
# Install file
# ============================================================

# 安装提示
# Install message
echo "正在安装 termux-tools... / Installing termux-tools..."

# 复制文件
# Copy file
cp "$SOURCE_FILE" "$TARGET_FILE"

# 添加可执行权限
# Add executable permission
#   +x: 增加 execute 位 / add execute bit
chmod +x "$TARGET_FILE"

# ============================================================
# 配置 PATH 环境变量
# Configure PATH environment variable
# ============================================================

# 检查目标目录是否已在 PATH
# Check if target dir already in PATH
#   ":$PATH:": 两端补冒号便于子串匹配 / wrap with colons for matching
#   != *":...:"*: 通配不匹配，说明不在
#   != *":...:"*: glob mismatch means not present
if [[ ":$PATH:" != *":$TARGET_DIR:"* ]]; then
    # 检测当前 shell 类型
    # Detect current shell type
    #   $SHELL: 用户默认 shell 路径 / user's default shell path
    #   basename: 取最后一段文件名 / extract last filename component
    SHELL_NAME="$(basename "$SHELL")"

    # 拼接对应的 rc 文件名（如 .bashrc / .zshrc）
    # Compose matching rc file (e.g. .bashrc / .zshrc)
    RC_FILE="$HOME/.${SHELL_NAME}rc"

    # 仅当 rc 文件存在时才修改
    # Only modify if rc file exists
    if [[ -f "$RC_FILE" ]]; then
        # 追加 PATH 导出语句到 rc 文件
        # Append PATH export to rc file
        #   单引号防止 $HOME / $PATH 在写入时展开
        #   single quotes prevent $HOME/$PATH expanding during write
        #   >>: 追加重定向 / append redirect
        echo 'export PATH="$HOME/.local/bin:$PATH"' >> "$RC_FILE"

        # 立即在当前 shell 生效
        # Apply to current shell session
        export PATH="$TARGET_DIR:$PATH"

        # 双语成功提示
        # Bilingual success notice
        echo "已将 $TARGET_DIR 添加到 PATH（$RC_FILE）"
        echo "Added $TARGET_DIR to PATH (in $RC_FILE)"
    fi
fi

# ============================================================
# 完成提示
# Completion message
# ============================================================
echo "安装完成！ / Installation complete!"
echo "运行 'termux-tools' 启动，或 'termux-tools help' 查看帮助。"
echo "Run 'termux-tools' to launch, or 'termux-tools help' for help."
