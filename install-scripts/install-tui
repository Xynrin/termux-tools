#!/usr/bin/env bash
#
# install-tui - 仅刷新 xynrin 软链 / Refresh the xynrin symlink only
#
# 当仓库已存在但 $PREFIX/bin/xynrin 损坏或缺失时使用
# Use when the repo exists but $PREFIX/bin/xynrin is broken or missing
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" &> /dev/null && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

SOURCE="$PROJECT_ROOT/tui/xynrin"
TARGET="$PREFIX/bin/xynrin"

if [[ ! -f "$SOURCE" ]]; then
    echo "错误：找不到 $SOURCE / Source not found"
    exit 1
fi

rm -f "$TARGET" "$PREFIX/bin/termux-tools"
ln -s "$SOURCE" "$TARGET"
chmod +x "$SOURCE"

echo "完成。运行 'xynrin' 启动。"
echo "Done. Run 'xynrin' to launch."
